{
  "name": "f95list-api",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/lib/swagger-theme && cp src/lib/swagger-theme/theme.css src/lib/swagger-theme/header.html src/lib/swagger-theme/banner.webp dist/lib/swagger-theme/",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "cz-emoji"
    },
    "cz-emoji": {
      "skipQuestions": [
        "body",
        "breaking",
        "issues",
        "scope"
      ],
      "types": [
        {
          "emoji": "🌟",
          "code": ":star2:",
          "description": "Nouvel endpoint ou comportement API",
          "name": "feat"
        },
        {
          "emoji": "🐞",
          "code": ":bug:",
          "description": "Correction API",
          "name": "fix"
        },
        {
          "emoji": "📚",
          "code": ":books:",
          "description": "Doc OpenAPI / README",
          "name": "docs"
        },
        {
          "emoji": "♻️",
          "code": ":recycle:",
          "description": "Refactor sans changement de contrat",
          "name": "refactor"
        },
        {
          "emoji": "🔩",
          "code": ":nut_and_bolt:",
          "description": "Tooling, deps, CI",
          "name": "chore"
        },
        {
          "emoji": "🚀",
          "code": ":rocket:",
          "description": "Release / bump de version",
          "name": "release"
        }
      ]
    }
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "mysql2": "^3.22.5",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "commitizen": "^4.3.2",
    "cz-emoji": "^1.3.2-canary.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
